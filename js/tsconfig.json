{
  "compilerOptions": {
    "declaration": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "dist/types",
    "strict": true,
    "target": "es2022",
    "types": [
      "node",
      "vitest"
    ]
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "vite.config.ts",
    "slim-shim.ts"
  ]
}